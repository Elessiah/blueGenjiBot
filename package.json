{
  "name": "bluegenjibot",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/main.js",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "gridfs-stream": "^1.1.1",
    "moment": "^2.30.1",
    "mongoose": "^8.7.0",
    "node-cron": "^4.2.1",
    "pm2": "^6.0.14",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "globals": "^15.10.0",
    "nodemon": "^3.1.7",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/main.ts\"",
    "genToken": "node dist/genToken.js",
    "lint": "eslint .",
    "docs:gen": "jsdoc -c jsdoc.json",
    "docs": "npm run build && npm run docs:gen",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "test:coverage": "npm run build && node --test --experimental-test-coverage \"dist/tests/**/*.test.js\""
  }
}
